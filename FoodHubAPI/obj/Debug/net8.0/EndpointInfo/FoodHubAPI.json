      "get": {
        "tags": [
          "AddReviews"
        ],
        "parameters": [
          {
            "name": "phone",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/AddReviews": {
      "post": {
        "tags": [
          "AddReviews"
